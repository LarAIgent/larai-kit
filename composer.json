{
    "name": "laraigent/larai-kit",
    "description": "Laravel RAG and AI agent toolkit — drop-in document ingestion, vector search, streaming chat, and multi-tenant scoping for Laravel 12/13. Works with OpenAI, Anthropic, Gemini, Pinecone, and pgvector.",
    "type": "library",
    "license": "MIT",
    "version": "0.2.3",
    "keywords": [
        "laravel",
        "laravel-package",
        "laravel-ai",
        "laravel-rag",
        "ai",
        "rag",
        "llm",
        "agent",
        "ai-agent",
        "chatbot",
        "openai",
        "anthropic",
        "claude",
        "gemini",
        "embeddings",
        "vector-search",
        "semantic-search",
        "pinecone",
        "pgvector",
        "document-ingestion",
        "pdf-parsing",
        "streaming",
        "sse",
        "multi-tenant"
    ],
    "homepage": "https://github.com/LarAIgent/larai-kit",
    "authors": [
        {
            "name": "LarAIgent",
            "homepage": "https://github.com/LarAIgent"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.0|^13.0",
        "laravel/ai": "^0.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "suggest": {
        "smalot/pdfparser": "Required for PDF document parsing (^2.0|^3.0)",
        "phpoffice/phpword": "Required for DOCX document parsing (^1.3)"
    },
    "autoload": {
        "psr-4": {
            "LarAIgent\\AiKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LarAIgent\\AiKit\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "LarAIgent\\AiKit\\AiKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
